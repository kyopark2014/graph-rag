};

const FONT_HEAD = "Calibri";
const FONT_BODY = "Calibri";

const POS_TITLE = { x: 0.33, y: 0.33, w: 12.67, h: 0.7 };

// ─── Shadow factory (no object reuse) ────────────────────────────────────────
const mkShadow = () => ({ type: "outer", blur: 6, offset: 2, angle: 135, color: "000000", opacity: 0.15 });

// ─── Background loaders ───────────────────────────────────────────────────────
function loadBg(name) {
  const buf = fs.readFileSync(path.join(ASSETS_DIR, `${name}.png`));
  return "image/png;base64," + buf.toString("base64");
}

// ─── AWS Logo loader ──────────────────────────────────────────────────────────
async function loadAwsLogo() {
  const logoPath = path.join(SKILL_DIR, "icons", "aws-logo.svg");
  if (!fs.existsSync(logoPath)) return null;
  const svg = fs.readFileSync(logoPath);
  const png = await sharp(svg).resize(200, 72).png().toBuffer();
  return "image/png;base64," + png.toString("base64");
}

// ─── Helper: AWS footer ───────────────────────────────────────────────────────
function addFooter(slide, awsLogoData) {
  if (awsLogoData) {
    slide.addImage({ data: awsLogoData, x: 0.47, y: 7.05, w: 0.7, h: 0.25 });
  }
  slide.addText("2025, Amazon Web Services, Inc. or its affiliates. All rights reserved.", {
    x: 1.3, y: 7.08, w: 10.0, h: 0.25,
    fontSize: 8, fontFace: FONT_BODY, color: C.slateGray,
  });
}

// ─── Helper: create gradient card background ──────────────────────────────────
async function gradCard(w, h, colors = [C.darkNavy, "0D1117"]) {
  const pw = Math.round(w * 96), ph = Math.round(h * 96);
  const [c1, c2] = colors;
  const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${pw}" height="${ph}">
    <defs>
      <linearGradient id="g" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#${c1}"/>
        <stop offset="100%" stop-color="#${c2}"/>
      </linearGradient>
    </defs>
    <rect width="${pw}" height="${ph}" rx="12" fill="url(#g)"/>
  </svg>`;
  const png = await sharp(Buffer.from(svg)).png().toBuffer();
  return "image/png;base64," + png.toString("base64");
}

// ─── Helper: load service icon ────────────────────────────────────────────────
async function loadIcon(name, size = 256) {
  const candidates = [name, name.toLowerCase(), name.replace(/ /g, "-").toLowerCase()];
  for (const c of candidates) {
    const p = path.join(SKILL_DIR, "icons", `${c}.svg`);
    if (fs.existsSync(p)) {
      const svg = fs.readFileSync(p);
      const png = await sharp(svg).resize(size, size).png().toBuffer();
      return "image/png;base64," + png.toString("base64");
    }
  }
  return null;
}

