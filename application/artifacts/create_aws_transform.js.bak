const pptxgen = require("pptxgenjs");
const fs = require("fs");
const path = require("path");
const sharp = require("sharp");

const ASSETS_DIR = path.join(__dirname, "myslide-assets");
const SKILL_DIR = path.join(__dirname, "../../skills/myslide");
const OUTPUT_PATH = path.join(__dirname, "aws-transform.pptx");

// ─── AWS Theme Constants ──────────────────────────────────────────────────────
const C = {
  bgBase:    "09051B",
  white:     "FFFFFF",
  orange:    "F66C02",
  pink:      "FF28EF",
  magenta:   "C91F8A",
  purple:    "5600C2",
  darkNavy:  "161E2D",
  lightSlate:"C8D0D8",
  slateGray: "8899AA",
