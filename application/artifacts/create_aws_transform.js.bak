      "CloudFormation Transform 문서",
      "AWS SAM GitHub",
    ];
    links.forEach((l, i) => {
      s.addText(l, {
        x: 8.0, y: 2.75 + i * 0.42, w: 5.0, h: 0.38,
        fontSize: 13, fontFace: FONT_BODY, color: C.lightSlate,
      });
    });

    addFooter(s, awsLogo);
  }

  // ── Save ───────────────────────────────────────────────────────────────────
  await pres.writeFile({ fileName: OUTPUT_PATH });
  console.log("✅ Saved:", OUTPUT_PATH);
}

main().catch((err) => { console.error(err); process.exit(1); });
